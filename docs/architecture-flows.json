    {
      "id": "auto-save",
      "label": "Auto-Save Project",
      "category": "editing",
      "description": "Project state is automatically saved after edits",
      "steps": [
        {
          "from": "command-manager",
          "to": "save-manager",
          "action": "markDirty()",
          "data": "Signal that project state has changed"
        },
        {
          "from": "save-manager",
          "to": "save-manager",
          "action": "Debounce (800ms)",
          "data": "Wait for edit burst to settle"
        },
        {
          "from": "save-manager",
          "to": "storage-service",
          "action": "saveProject()",
          "data": "Serialize full project state"
        },
        {
          "from": "storage-service",
          "to": "indexeddb",
          "action": "Write project + scenes + tracks",
          "data": "{ metadata, scenes, currentSceneId, settings, version }"
        },
        {
          "from": "storage-service",
          "to": "storage-service",
          "action": "Run migrations if needed",
          "data": "Check version, apply schema updates"
        }
      ]
    },
    {
      "id": "render-preview",
      "label": "Render Preview Frame",
      "category": "editing",
      "description": "A single frame is rendered for the preview panel",
      "steps": [
        {
          "from": "playback-manager",
          "to": "renderer-manager",
          "action": "Request frame at currentTime",
          "data": "{ time, canvasSize }"
        },
        {
          "from": "renderer-manager",
          "to": "scene-graph",
          "action": "buildScene()",
          "data": "RootNode tree from current tracks state"
        },
        {
          "from": "scene-graph",
          "to": "scene-graph",
          "action": "resolveRenderTree(node, time)",
          "data": "Resolve all node state at specific time"
        },
        {
          "from": "scene-graph",
          "to": "renderer-manager",
          "action": "buildFrameDescriptor()",
          "data": "WASM-compatible frame description"
        },
        {
          "from": "renderer-manager",
          "to": "wasm-compositor",
          "action": "syncTextures()",
          "data": "Upload OffscreenCanvas textures to GPU"
        },
        {
          "from": "renderer-manager",
          "to": "wasm-compositor",
          "action": "renderFrame(frameDescriptor)",
          "data": "GPU composite → output canvas"
        },
        {
          "from": "wasm-compositor",
          "to": "web-gpu",
          "action": "wgpu render pass",
          "data": "Texture uploads → shader execution → surface present"
        },
        {
          "from": "wasm-compositor",
          "to": "react-ui",
          "action": "Canvas element updated",
          "data": "Preview panel shows rendered frame"
        }
      ]
    },
    {
      "id": "apply-effect",
      "label": "Apply GPU Effect",
      "category": "editing",
      "description": "User applies a visual effect to a clip",
      "steps": [
        {
          "from": "user",
          "to": "react-ui",
          "action": "Select effect from effects panel",
          "data": "Effect type + parameters"
        },
        {
          "from": "react-ui",
          "to": "timeline-manager",
          "action": "AddClipEffectCommand",
          "data": "{ clipId, effectType, params }"
        },
        {
          "from": "timeline-manager",
          "to": "command-manager",
          "action": "execute(command)",
          "data": "Push to undo stack"
        },
        {
          "from": "timeline-manager",
          "to": "renderer-manager",
          "action": "Re-render preview",
          "data": "Scene graph includes new effect node"
        },
        {
          "from": "renderer-manager",
          "to": "effects-pipeline",
          "action": "applyEffectPasses()",
          "data": "GPU shader execution with params"
        },
        {
          "from": "effects-pipeline",
          "to": "web-gpu",
          "action": "Compute shader pass",
          "data": "Source texture → effect → output OffscreenCanvas"
        },
        {
          "from": "effects-pipeline",
          "to": "renderer-manager",
          "action": "Return processed frame",
          "data": "OffscreenCanvas with effect applied"
        },
        {
          "from": "renderer-manager",
          "to": "react-ui",
          "action": "Preview updated",
          "data": "Effect visible in preview panel"
        }
      ]
    },
    {
      "id": "copy-paste",
      "label": "Copy / Paste Elements",
      "category": "editing",
      "description": "User copies and pastes timeline elements",
      "steps": [
        {
          "from": "user",
          "to": "react-ui",
          "action": "Select elements, press Ctrl+C",
          "data": "Selected element IDs"
        },
        {
          "from": "react-ui",
          "to": "action-registry",
          "action": "invokeAction('copy-selected')",
          "data": "Copy signal"
        },
        {
          "from": "action-registry",
          "to": "clipboard-manager",
          "action": "copy(elements)",
          "data": "Serialize elements to clipboard"
        },
        {
          "from": "user",
          "to": "react-ui",
          "action": "Move playhead, press Ctrl+V",
          "data": "Paste signal"
        },
        {
          "from": "react-ui",
          "to": "action-registry",
          "action": "invokeAction('paste-copied')",
          "data": "Paste signal"
        },
        {
          "from": "action-registry",
          "to": "clipboard-manager",
          "action": "paste()",
          "data": "Deserialize elements from clipboard"
        },
        {
          "from": "clipboard-manager",
          "to": "timeline-manager",
          "action": "InsertElementCommand",
          "data": "New elements at playhead position"
        },
        {
          "from": "timeline-manager",
          "to": "command-manager",
          "action": "execute(command)",
          "data": "Push to undo stack"
        },
        {
          "from": "timeline-manager",
          "to": "renderer-manager",
          "action": "Re-render preview",
          "data": "Pasted elements visible"
        }
      ]
    }
  ]
}
