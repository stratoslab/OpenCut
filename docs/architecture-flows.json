        },
        {
          "from": "github-actions",
          "to": "github-actions",
          "action": "Install Bun 1.2.18, cache modules",
          "data": "Package manager setup"
        },
        {
          "from": "github-actions",
          "to": "github-actions",
          "action": "bun install",
          "data": "All workspace dependencies"
        },
        {
          "from": "github-actions",
          "to": "github-actions",
          "action": "cd apps/web-vite && bun run build",
