{
  "version": "2.0",
  "description": "OpenCut (StratosLab fork) architecture workflows — Vite + React SPA, fully client-side",
  "nodes": {
    "user": {
      "id": "user",
      "label": "User",
      "type": "external",
      "icon": "👤",
      "description": "End user interacting with the application"
    },
    "browser": {
      "id": "browser",
      "label": "Browser",
      "type": "runtime",
      "icon": "🌐",
      "description": "Web browser runtime (WebGPU, Web Audio API, Web Workers)"
    },
    "react-ui": {
      "id": "react-ui",
      "label": "React UI",
      "type": "component",
      "package": "@opencut/web-vite",
      "icon": "⚛️",
      "description": "React components: panels, timeline, preview, editor (Vite SPA)"
    },
    "action-registry": {
      "id": "action-registry",
      "label": "Action Registry",
      "type": "component",
      "package": "@opencut/web-vite",
      "icon": "⌨️",
      "description": "Keyboard shortcuts → action invocation (22+ actions)"
    },
    "editor-core": {
      "id": "editor-core",
      "label": "EditorCore",
      "type": "singleton",
      "package": "@opencut/web-vite",
      "icon": "🎯",
      "description": "Central orchestrator — all managers instantiated here"
    },
    "command-manager": {
      "id": "command-manager",
      "label": "CommandManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "📋",
      "description": "Undo/redo history, command execution, ripple adjustments"
    },
    "timeline-manager": {
      "id": "timeline-manager",
      "label": "TimelineManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "🎬",
      "description": "Track/element CRUD, keyframes, effects, masks, transitions"
    },
    "playback-manager": {
      "id": "playback-manager",
      "label": "PlaybackManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "▶️",
      "description": "Play/pause/seek, rAF loop, time updates"
    },
    "audio-manager": {
      "id": "audio-manager",
      "label": "AudioManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "🔊",
      "description": "Web Audio API playback, clip scheduling, retime"
    },
    "renderer-manager": {
      "id": "renderer-manager",
      "label": "RendererManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "🖼️",
      "description": "Canvas rendering, snapshots, export pipeline"
    },
    "save-manager": {
      "id": "save-manager",
      "label": "SaveManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "💾",
      "description": "Debounced auto-save (800ms)"
    },
    "media-manager": {
      "id": "media-manager",
      "label": "MediaManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "📁",
      "description": "Media asset add/remove, cache management"
    },
    "scenes-manager": {
      "id": "scenes-manager",
      "label": "ScenesManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "🎞️",
      "description": "Scene CRUD, bookmarks, track updates"
    },
    "selection-manager": {
      "id": "selection-manager",
      "label": "SelectionManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "🖱️",
      "description": "Element/keyframe/mask-point selection state"
    },
    "clipboard-manager": {
      "id": "clipboard-manager",
      "label": "ClipboardManager",
      "type": "manager",
      "package": "@opencut/web-vite",
      "icon": "📎",
      "description": "Copy/paste timeline elements"
    },
    "wasm-compositor": {
      "id": "wasm-compositor",
      "label": "WASM Compositor",
      "type": "wasm",
      "package": "opencut-wasm",
      "icon": "⚙️",
      "description": "GPU video frame compositing via wgpu (WebGPU)"
    },
    "effects-pipeline": {
      "id": "effects-pipeline",
      "label": "Effects Pipeline",
      "type": "wasm",
      "package": "opencut-wasm",
      "icon": "✨",
      "description": "GPU shader effect pipeline"
    },
    "mask-pipeline": {
      "id": "mask-pipeline",
      "label": "Mask Pipeline",
      "type": "wasm",
      "package": "opencut-wasm",
      "icon": "🎭",
      "description": "Mask feathering via Gaussian blur"
    },
    "transitions-pipeline": {
      "id": "transitions-pipeline",
      "label": "Transitions Pipeline",
      "type": "component",
      "package": "@opencut/web-vite",
      "icon": "🔄",
      "description": "Canvas 2D transition rendering (crossfade, slide, wipe, zoom)"
    },
    "storage-service": {
      "id": "storage-service",
      "label": "StorageService",
      "type": "service",
      "package": "@opencut/web-vite",
      "icon": "🗄️",
      "description": "IndexedDB (metadata) + OPFS (media binaries)"
    },
    "transcription-service": {
      "id": "transcription-service",
      "label": "TranscriptionService",
      "type": "service",
      "package": "@opencut/web-vite",
      "icon": "🎙️",
      "description": "Whisper ONNX transcription via Web Worker"
    },
    "transcript-editor": {
      "id": "transcript-editor",
      "label": "TranscriptEditor",
      "type": "component",
      "package": "@opencut/web-vite",
      "icon": "📝",
      "description": "Word-level transcript UI with timeline sync"
    },
    "text-edit-engine": {
      "id": "text-edit-engine",
      "label": "TextEditEngine",
      "type": "engine",
      "package": "@opencut/web-vite",
      "icon": "✂️",
      "description": "Deterministic text → timestamp → timeline cuts"
    },
    "gemma-chat": {
      "id": "gemma-chat",
      "label": "Gemma Chat",
      "type": "component",
      "package": "@opencut/web-vite",
      "icon": "🤖",
      "description": "Local Gemma LLM conversational assistant (WebGPU)"
    },
    "export-pipeline": {
      "id": "export-pipeline",
      "label": "Export Pipeline",
      "type": "service",
      "package": "@opencut/web-vite",
      "icon": "📤",
      "description": "Browser-native MP4/WebM export (MediaRecorder + Canvas capture)"
    },
    "scene-graph": {
      "id": "scene-graph",
      "label": "Scene Graph",
      "type": "service",
      "package": "@opencut/web-vite",
      "icon": "🌳",
      "description": "RootNode → VideoNode/TextNode/ImageNode tree"
    },
    "sounds-proxy-worker": {
      "id": "sounds-proxy-worker",
      "label": "Sounds Proxy Worker",
      "type": "server",
      "package": "Cloudflare Worker",
      "icon": "🔌",
      "description": "Stateless Worker proxying Freesound API (hides API key)"
    },
    "freesound-api": {
      "id": "freesound-api",
      "label": "Freesound API",
      "type": "external",
      "icon": "🎵",
      "description": "Audio asset search and download"
    },
    "cloudflare-pages": {
      "id": "cloudflare-pages",
      "label": "Cloudflare Pages",
      "type": "deploy",
      "icon": "☁️",
      "description": "Production deployment — static files, unlimited size"
    },
    "github-actions": {
      "id": "github-actions",
      "label": "GitHub Actions",
      "type": "deploy",
      "icon": "🔄",
      "description": "CI: WASM build → Bun install → Vite build"
    },
    "todesktop": {
      "id": "todesktop",
      "label": "ToDesktop",
      "type": "deploy",
      "icon": "🖥️",
      "description": "Desktop app packaging (Electron-based)"
    },
    "indexeddb": {
      "id": "indexeddb",
      "label": "IndexedDB",
      "type": "external",
      "icon": "📊",
      "description": "Project metadata, scenes, tracks, media metadata"
    },
    "opfs": {
      "id": "opfs",
      "label": "OPFS",
      "type": "external",
      "icon": "📦",
      "description": "Origin Private File System — media binaries"
    },
    "web-worker": {
      "id": "web-worker",
      "label": "Web Worker",
      "type": "runtime",
      "icon": "👷",
      "description": "Background thread for Whisper transcription"
    },
    "web-gpu": {
      "id": "web-gpu",
      "label": "WebGPU",
      "type": "runtime",
      "icon": "🎮",
      "description": "Browser GPU API for WASM compositor"
    },
    "web-audio": {
      "id": "web-audio",
      "label": "Web Audio API",
      "type": "runtime",
      "icon": "🔈",
      "description": "Browser audio API for playback scheduling"
    },
    "video-element": {
      "id": "video-element",
      "label": "HTMLVideoElement",
      "type": "runtime",
      "icon": "🎬",
      "description": "Native video playback for frame extraction (replaces mediabunny)"
    },
    "media-recorder": {
      "id": "media-recorder",
      "label": "MediaRecorder API",
      "type": "runtime",
      "icon": "⏺️",
      "description": "Browser-native video encoding for export (replaces mediabunny)"
    }
  },
  "flows": [
    {
      "id": "user-imports-media",
      "label": "Import Media",
      "category": "editing",
      "description": "User imports a video/audio/image file into the project",
      "steps": [
        {
          "from": "user",
          "to": "react-ui",
          "action": "Drag & drop or file picker",
          "data": "File object (video/audio/image)"
        },
        {
          "from": "react-ui",
          "to": "media-manager",
          "action": "addMediaAsset()",
          "data": "File → ArrayBuffer + metadata extraction"
        },
        {
          "from": "media-manager",
          "to": "opfs",
          "action": "Write media binary",
          "data": "ArrayBuffer stored in OPFS per projectId"
        },
        {
          "from": "media-manager",
          "to": "indexeddb",
          "action": "Store media metadata",
          "data": "{ id, name, type, duration, width, height, projectId }"
        },
        {
          "from": "media-manager",
          "to": "scenes-manager",
          "action": "Create timeline element",
          "data": "VideoElement/ImageElement/AudioElement with mediaId reference"
        },
        {
          "from": "scenes-manager",
          "to": "command-manager",
          "action": "execute(AddMediaAssetCommand)",
          "data": "Command pushed to undo stack"
        },
        {
          "from": "command-manager",
          "to": "save-manager",
          "action": "markDirty()",
          "data": "Debounced save triggered (800ms)"
        },
        {
          "from": "save-manager",
          "to": "storage-service",
          "action": "saveProject()",
          "data": "Full project state → IndexedDB"
        }
      ]
    },
    {
      "id": "user-edits-timeline",
      "label": "Edit Timeline (Split/Delete/Move)",
      "category": "editing",
      "description": "User modifies timeline elements via UI or keyboard shortcuts",
      "steps": [
        {
          "from": "user",
          "to": "react-ui",
          "action": "Click/drag on timeline or press shortcut",
          "data": "Element ID, action type, parameters"
        },
        {
          "from": "react-ui",
          "to": "action-registry",
          "action": "invokeAction()",
          "data": "{ action: 'split' | 'delete-selected' | 'copy-selected', ... }"
        },
        {
          "from": "action-registry",
          "to": "editor-core",
          "action": "Route to appropriate manager",
          "data": "Action → TimelineManager / ScenesManager"
        },
        {
          "from": "editor-core",
          "to": "command-manager",
          "action": "execute(command)",
          "data": "SplitElementsCommand / DeleteElementsCommand / etc."
        },
        {
          "from": "command-manager",
          "to": "timeline-manager",
          "action": "command.execute()",
          "data": "Mutate scene tracks: split clips, adjust trimStart/trimEnd"
        },
        {
          "from": "timeline-manager",
          "to": "command-manager",
          "action": "Ripple adjustment (if enabled)",
          "data": "Shift subsequent clips to close gaps"
        },
        {
          "from": "command-manager",
          "to": "command-manager",
          "action": "Push to undo history",
          "data": "{ undo: inverseCommand, redo: command }"
        },
        {
          "from": "command-manager",
          "to": "scenes-manager",
          "action": "updateSceneTracks()",
          "data": "Notify all listeners of track changes"
        },
        {
          "from": "scenes-manager",
          "to": "renderer-manager",
          "action": "Re-render preview",
          "data": "Scene graph rebuilt → WASM composite"
        },
        {
          "from": "scenes-manager",
          "to": "save-manager",
          "action": "markDirty()",
          "data": "Debounced auto-save"
        }
      ]
    },
    {
      "id": "user-plays-video",
      "label": "Playback",
      "category": "editing",
      "description": "User presses play to preview the video",
      "steps": [
        {
          "from": "user",
          "to": "react-ui",
          "action": "Click play button or press Space",
          "data": "Play/pause toggle"
        },
        {
          "from": "react-ui",
          "to": "action-registry",
          "action": "invokeAction('toggle-play')",
          "data": "Action signal"
        },
        {
          "from": "action-registry",
          "to": "playback-manager",
          "action": "play() / pause()",
          "data": "Playback state change"
        },
        {
          "from": "playback-manager",
          "to": "browser",
          "action": "requestAnimationFrame loop",
          "data": "updateTime() called every frame (~60fps)"
        },
        {
          "from": "playback-manager",
          "to": "renderer-manager",
          "action": "Render frame at currentTime",
          "data": "{ time, canvasSize, tracks } → WASM renderFrame()"
        },
        {
          "from": "renderer-manager",
          "to": "wasm-compositor",
          "action": "renderFrame(frameDescriptor)",
          "data": "GPU composite all layers → output canvas"
        },
        {
          "from": "playback-manager",
          "to": "audio-manager",
          "action": "handlePlaybackChange()",
          "data": "{ playing, time, speed }"
        },
        {
          "from": "audio-manager",
          "to": "web-audio",
          "action": "scheduleAudioClips()",
          "data": "Web Audio API: lookahead 2s window, 500ms interval"
        },
        {
          "from": "playback-manager",
          "to": "react-ui",
          "action": "Notify time update",
          "data": "Timeline ruler + preview update via useSyncExternalStore"
        }
      ]
    },
    {
      "id": "user-transcribes-video",
      "label": "Transcribe Video",
      "category": "ai",
      "description": "User runs Whisper transcription on video audio",
      "steps": [
        {
          "from": "user",
          "to": "react-ui",
          "action": "Click 'Transcribe' button",
          "data": "Video element reference"
        },
        {
          "from": "react-ui",
          "to": "transcription-service",
          "action": "transcribeToWords()",
          "data": "Audio extracted as Float32Array (16kHz mono)"
        },
        {
          "from": "transcription-service",
          "to": "web-worker",
          "action": "Post message: { type: 'transcribe', audio }",
          "data": "Float32Array transferred to worker"
        },
        {
          "from": "web-worker",
          "to": "web-worker",
          "action": "Load Whisper ONNX model",
          "data": "Model download → progress_callback reports %"
        },
        {
          "from": "web-worker",
          "to": "web-worker",
          "action": "Run inference",
          "data": "Audio → segments with timestamps"
        },
        {
          "from": "web-worker",
          "to": "transcription-service",
          "action": "Post message: { type: 'transcribe-complete' }",
          "data": "{ text, segments: [{ text, start, end }] }"
        },
        {
          "from": "transcription-service",
          "to": "transcription-service",
          "action": "segmentsToWordSegments()",
          "data": "Split sentence segments → word-level with estimated timestamps"
        },
        {
          "from": "transcription-service",
          "to": "transcript-editor",
          "action": "Set WordTranscript",
          "data": "{ words: WordSegment[], fullText, language, videoDuration }"
        },
        {
          "from": "transcript-editor",
          "to": "react-ui",
          "action": "Render transcript view",
          "data": "Interactive text with word-level hover/click"
        }
      ]
    },
    {
      "id": "user-edits-by-text",
      "label": "Text-Based Video Editing",
      "category": "ai",
      "description": "User deletes text from transcript → corresponding video is cut",
      "steps": [
        {
          "from": "user",
          "to": "transcript-editor",
          "action": "Select and delete text",
          "data": "Text selection range"
        },
        {
          "from": "transcript-editor",
          "to": "text-edit-engine",
          "action": "applyTextEdit(originalText, editedText)",
          "data": "Diff calculation → deleted word indices"
        },
        {
          "from": "text-edit-engine",
          "to": "text-edit-engine",
          "action": "aggregateTimestamps()",
          "data": "Word indices → [{ start, end }] time ranges"
        },
        {
          "from": "text-edit-engine",
          "to": "text-edit-engine",
          "action": "computeTimelineCuts()",
          "data": "Time ranges → CutOperation[] (trim/split/delete)"
        },
        {
          "from": "text-edit-engine",
          "to": "react-ui",
          "action": "Show EditPreviewPanel",
          "data": "{ deletedText, timeRange, affectedClips }"
        },
        {
          "from": "user",
          "to": "react-ui",
          "action": "Click 'Apply Cuts'",
          "data": "Confirmation"
        },
        {
          "from": "react-ui",
          "to": "text-edit-engine",
          "action": "applyRippleEdit()",
          "data": "Close gaps by shifting subsequent clips"
        },
        {
          "from": "text-edit-engine",
          "to": "timeline-manager",
          "action": "Update VideoElements",
          "data": "New clip arrangement with adjusted startTime/duration"
        },
        {
          "from": "timeline-manager",
          "to": "renderer-manager",
          "action": "Re-render preview",
          "data": "Updated scene graph → WASM composite"
        },
        {
          "from": "timeline-manager",
          "to": "save-manager",
          "action": "markDirty()",
          "data": "Auto-save updated project state"
        }
      ]
    },
    {
      "id": "user-chats-with-gemma",
      "label": "AI Chat — Ask Gemma",
      "category": "ai",
      "description": "User asks Gemma LLM about video content or requests edit suggestions",
      "steps": [
        {
          "from": "user",
          "to": "gemma-chat",
          "action": "Type question or edit request",
          "data": "Natural language query"
        },
        {
          "from": "gemma-chat",
          "to": "gemma-chat",
          "action": "chunkTranscript()",
          "data": "Split transcript into ≤4096 token chunks with word timings"
        },
        {
          "from": "gemma-chat",
          "to": "browser",
          "action": "Send to local Gemma model (WebGPU)",
          "data": "Prompt: system + transcript context + user query"
        },
        {
          "from": "browser",
          "to": "gemma-chat",
          "action": "Stream response",
          "data": "Text response (may include JSON edit suggestions)"
        },
        {
          "from": "gemma-chat",
          "to": "gemma-chat",
          "action": "parseLLMResponse()",
          "data": "Extract { description, start, end } from response"
        },
        {
          "from": "gemma-chat",
          "to": "react-ui",
          "action": "Display suggestions as clickable cards",
          "data": "Edit suggestions with time ranges"
        },
        {
          "from": "user",
          "to": "react-ui",
          "action": "Click suggestion to apply",
          "data": "EditSuggestion → flows through TextEditEngine"
        }
      ]
    },
    {
      "id": "user-exports-video",
      "label": "Export Video",
      "category": "editing",
      "description": "User exports the edited video as MP4/WebM",
      "steps": [
        {
          "from": "user",
          "to": "react-ui",
          "action": "Click 'Export' button, select format/quality",
          "data": "{ format: 'mp4' | 'webm', quality, fps, includeAudio }"
        },
        {
          "from": "react-ui",
          "to": "renderer-manager",
          "action": "exportProject(options)",
          "data": "Export configuration"
        },
        {
          "from": "renderer-manager",
          "to": "renderer-manager",
          "action": "createTimelineAudioBuffer()",
          "data": "Mix all audio tracks → AudioBuffer (~5% progress)"
        },
        {
          "from": "renderer-manager",
          "to": "scene-graph",
          "action": "buildScene()",
          "data": "RootNode tree from tracks + mediaAssets + canvasSize"
        },
        {
          "from": "scene-graph",
          "to": "export-pipeline",
          "action": "SceneExporter.export()",
          "data": "Frame-by-frame render loop"
        },
        {
          "from": "export-pipeline",
          "to": "wasm-compositor",
          "action": "renderFrame() per frame",
          "data": "Each frame composited via GPU"
        },
        {
          "from": "export-pipeline",
          "to": "video-element",
          "action": "captureStream() from canvas",
          "data": "Canvas video stream + audio track"
        },
        {
          "from": "export-pipeline",
          "to": "media-recorder",
          "action": "MediaRecorder.encode()",
          "data": "VP9 (WebM) or H.264 (MP4) + Opus/AAC audio"
        },
        {
          "from": "export-pipeline",
          "to": "user",
          "action": "Download file",
          "data": "Blob → browser download"
        }
      ]
    },
    {
      "id": "user-undo-redo",
      "label": "Undo / Redo",
      "category": "editing",
      "description": "User undoes or redoes timeline edits",
      "steps": [
        {
          "from": "user",
          "to": "react-ui",
          "action": "Press Ctrl+Z / Ctrl+Y or click undo/redo",
          "data": "Undo/redo signal"
        },
        {
          "from": "react-ui",
          "to": "action-registry",
          "action": "invokeAction('undo' | 'redo')",
          "data": "Action signal"
        },
        {
          "from": "action-registry",
          "to": "command-manager",
          "action": "undo() / redo()",
          "data": "Pop from undo/redo stack"
        },
        {
          "from": "command-manager",
          "to": "command-manager",
          "action": "Execute inverse command",
          "data": "undo: inverseCommand.execute()"
        },
        {
          "from": "command-manager",
          "to": "timeline-manager",
          "action": "Restore previous state",
          "data": "Scene tracks reverted to snapshot"
        },
        {
          "from": "timeline-manager",
          "to": "scenes-manager",
          "action": "updateSceneTracks()",
          "data": "Notify listeners of state change"
        },
        {
          "from": "scenes-manager",
          "to": "renderer-manager",
          "action": "Re-render preview",
          "data": "Preview reflects undone/redone state"
        },
        {
          "from": "scenes-manager",
          "to": "save-manager",
          "action": "markDirty()",
          "data": "Auto-save restored state"
        }
      ]
    },
    {
      "id": "user-searches-sounds",
      "label": "Search Audio Assets",
      "category": "assets",
      "description": "User searches for audio assets via Freesound API (proxied through stateless Worker)",
      "steps": [
        {
          "from": "user",
          "to": "react-ui",
          "action": "Type search query in sounds panel",
          "data": "Search string + filters (type, rating, license)"
        },
        {
          "from": "react-ui",
          "to": "sounds-proxy-worker",
          "action": "GET /api/sounds/search",
          "data": "{ query, filters }"
        },
        {
          "from": "sounds-proxy-worker",
          "to": "freesound-api",
          "action": "Proxy request with API key",
          "data": "Freesound API key + search params"
        },
        {
          "from": "freesound-api",
          "to": "sounds-proxy-worker",
          "action": "Return search results",
          "data": "Audio metadata + preview URLs"
        },
        {
          "from": "sounds-proxy-worker",
          "to": "react-ui",
          "action": "Return transformed results",
          "data": "Standardized sound objects for UI display"
        },
        {
          "from": "user",
          "to": "react-ui",
          "action": "Click to download/save sound",
          "data": "Sound ID"
        },
        {
          "from": "react-ui",
          "to": "indexeddb",
          "action": "Store in saved sounds",
          "data": "Sound metadata + audio blob"
        }
      ]
    },
    {
      "id": "ci-build",
